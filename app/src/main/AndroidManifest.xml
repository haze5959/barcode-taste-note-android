<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- 햅틱 피드백 (OQHapticService). iOS 의 UIImpactFeedbackGenerator 등가 — VIBRATE 없으면 SecurityException. -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- 시음 노트 예약 로컬 알림 (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- AlarmManager 정확 시간 알림 (Android 12+) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- FCM -->
    <uses-permission android:name="com.google.android.c2dm.permission.RECEIVE" />
    <!-- Google Play Billing (구독) -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Android 11+ package visibility 정책. 외부 앱 설치 여부 조회/실행 시 필요.
         iOS `LSApplicationQueriesSchemes` 대응 (kakaolink / instagram-stories). -->
    <queries>
        <package android:name="com.kakao.talk" />
        <!-- Instagram Stories 공유(ADD_TO_STORY) 대상 / 설치 여부 조회. -->
        <package android:name="com.instagram.android" />
    </queries>

    <application
        android:name=".BarNoteApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.BarNote">

        <!-- ML Kit Barcode 모델 사전 다운로드 (앱 설치 직후) -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode" />

        <!-- Firebase Analytics: 자동 screen view 보고 비활성 (iOS `FirebaseAutomaticScreenReportingEnabled: false` 대응).
             현재 명시적 screen view 호출도 없으므로 사실상 화면 추적 미사용. -->
        <meta-data
            android:name="google_analytics_automatic_screen_reporting_enabled"
            android:value="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Auth0 Web Auth 콜백 intent-filter 는 여기 선언하지 않는다 (의도적).
                 Auth0 SDK 가 com.auth0.android.provider.RedirectActivity 를 manifestPlaceholders
                 (auth0Domain/auth0Scheme)로 자동 구성해 동일 콜백 URI 를 처리하고 WebAuth 흐름을 resume 한다.
                 MainActivity 에 같은 URI(scheme=${auth0Scheme}, host=${auth0Domain},
                 pathPrefix=/android/${applicationId}/callback)를 또 선언하면 RedirectActivity 와 충돌해,
                 로그인 후 콜백이 RedirectActivity 로 가지 못하고 앱이 백그라운드에 머무른다. -->

            <!-- App deep link (barnote://note/{uuid}, barnote://user/{uuid}) -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="barnote" android:host="note" />
                <data android:scheme="barnote" android:host="user" />
            </intent-filter>

            <!-- 웹 App Link (https://barnote.net/note/{uuid}, https://barnote.net/user/{uuid})
                 iOS Universal Links 등가. autoVerify="true" 로 App Links 자동 검증 활성화 →
                 검증 성공 시 "어떤 앱으로 열까요?" 다이얼로그 없이 곧바로 앱이 처리.

                 ⚠️ 서버 의존: 검증을 위해 https://barnote.net/.well-known/assetlinks.json 호스팅 필요
                 (iOS apple-app-site-association 과 동일 모델). 템플릿: app/src/main/assetlinks.template.json.
                 서버 호스팅 전까지는 https 링크가 시스템 브라우저로 폴백되며, 앱 내 deep link 는
                 barnote:// 커스텀 스킴(아래 verify 불필요)으로 항상 동작합니다. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="barnote.net" android:pathPrefix="/note/" />
                <data android:scheme="https" android:host="barnote.net" android:pathPrefix="/user/" />
            </intent-filter>

            <!-- Kakao SDK 콜백 (카카오톡 공유 / 향후 카카오 로그인 콜백용).
                 iOS `CFBundleURLSchemes: kakao{appKey}` 대응. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kakao${kakaoNativeAppKey}" android:host="oauth" />
            </intent-filter>
        </activity>

        <!-- FCM 토큰 갱신 / 메시지 수신 -->
        <service
            android:name="com.oq.barnote.core.data.fcm.BarNoteMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- 시음 노트 예약 알림: AlarmManager trigger -->
        <receiver
            android:name="com.oq.barnote.core.data.notification.NotificationAlarmReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.oq.barnote.NOTE_RESERVATION" />
            </intent-filter>
        </receiver>

        <!-- 알림 탭 처리: 별도 Receiver 가 없습니다.
             모든 알림은 PendingIntent.getActivity 로 MainActivity 를 직접 launch 하고,
             MainActivity 가 NotificationTapDispatch.parseEvent 로 이벤트를 추출해
             NotificationSchedulerImpl.emitEvent 합니다 (iOS `didReceive response` 등가). -->

        <!-- 시음노트 데이터 내보내기 등 외부 앱과 임시 파일 공유 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
